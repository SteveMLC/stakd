{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "sortbloom-web",
      "runtimeExecutable": "flutter",
      "runtimeArgs": [
        "run",
        "-d",
        "web-server",
        "--web-port",
        "8765",
        "--web-hostname",
        "localhost",
        "--release"
      ],
      "port": 8765
    },
    {
      "name": "sortbloom-web-debug",
      "runtimeExecutable": "flutter",
      "runtimeArgs": [
        "run",
        "-d",
        "web-server",
        "--web-port",
        "8765",
        "--web-hostname",
        "localhost"
      ],
      "port": 8765
    }
  ]
}
